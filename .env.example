# Optional: enables Google Custom Search fallback snippets in backend/search_module.py
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional: message length guard for /api/chat (0 = unlimited)
ASSERI_MAX_MESSAGE_CHARS=0

# Optional: auth session lifetime in hours (default: 720 = 30 days)
ASSERI_AUTH_SESSION_HOURS=720

# Optional: startup host/port override for python main.py
ASSERI_HOST=127.0.0.1
ASSERI_PORT=8000
